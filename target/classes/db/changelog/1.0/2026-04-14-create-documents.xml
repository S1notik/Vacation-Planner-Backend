<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="2026-04-14-create-documents" author="vacation-planner">
        <createTable tableName="documents">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="vacation_request_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_documents_vacation_request"
                             references="vacation_requests(id)"
                             deleteCascade="true"/>
            </column>
            <column name="file_url" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="generated_at" type="timestamp" defaultValueComputed="now()"/>
        </createTable>

        <createIndex tableName="documents" indexName="idx_documents_vr_id">
            <column name="vacation_request_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>