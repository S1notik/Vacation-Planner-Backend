<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="2026-04-14-create-team-members" author="vacation-planner">
        <createTable tableName="team_members">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="team_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_team_members_team"
                             references="teams(id)"
                             deleteCascade="true"/>
            </column>
            <column name="user_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_team_members_user"
                             references="users(id)"
                             deleteCascade="true"/>
            </column>
            <column name="joined_at" type="timestamp" defaultValueComputed="now()"/>
        </createTable>

        <addUniqueConstraint tableName="team_members"
                             columnNames="team_id, user_id"
                             constraintName="uq_team_members_team_user"/>

        <createIndex tableName="team_members" indexName="idx_team_members_team_id">
            <column name="team_id"/>
        </createIndex>
        <createIndex tableName="team_members" indexName="idx_team_members_user_id">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>