<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="2026-04-14-create-teams" author="vacation-planner">
        <createTable tableName="teams">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="employer_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_teams_employer"
                             references="users(id)"
                             deleteCascade="false"/>
            </column>
            <column name="invite_code" type="varchar(64)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_teams_invite_code"/>
            </column>
            <column name="invite_qr_url" type="text"/>
            <column name="created_at" type="timestamp" defaultValueComputed="now()"/>
        </createTable>

        <createIndex tableName="teams" indexName="idx_teams_employer_id">
            <column name="employer_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>